{
  "name": "Little Lanterns Web Design System",
  "version": "1.1.0",
  "issue": "LIT-69",
  "a11yIssue": "LIT-74",
  "visualSystem": "Porch Lantern Folklore",
  "sources": ["LIT-15", "LIT-59", "LIT-65"],
  "color": {
    "locked": {
      "lanternAmber": "#E4A01A",
      "nightTeal": "#163A3F",
      "mistPaper": "#EEF2EF",
      "emberCoral": "#D45A3A",
      "softSage": "#8FA88A",
      "porchBlue": "#2C4A62",
      "fireflyLime": "#C6D96A",
      "windowWarm": "#F3D9A0"
    },
    "semantic": {
      "bg": "mistPaper",
      "bgInverse": "nightTeal",
      "bgDusk": "porchBlue",
      "text": "nightTeal",
      "textOnInverse": "mistPaper",
      "brand": "nightTeal",
      "accent": "lanternAmber",
      "accentSoft": "windowWarm",
      "calm": "softSage",
      "neighbor": "fireflyLime",
      "stakes": "emberCoral",
      "link": "porchBlue",
      "focus": "lanternAmber"
    },
    "avoid": [
      "purple-to-indigo gradients",
      "cream + terracotta farmhouse stack",
      "pure-black crushed vignettes",
      "glitter sparkle swarms",
      "page-wide amber glow (glow stays local to lantern imagery)"
    ]
  },
  "typography": {
    "display": {
      "family": "Fraunces",
      "fallback": ["Palatino Linotype", "Palatino", "serif"],
      "weights": [500, 600, 700],
      "opticalSizing": "9..144"
    },
    "body": {
      "family": "Source Sans 3",
      "fallback": ["Source Sans Pro", "Segoe UI", "sans-serif"],
      "weights": [400, 500, 600, 700]
    },
    "scale": {
      "displayXl": "clamp(2.5rem, 1.8rem + 2.8vw, 3.75rem)",
      "displayLg": "clamp(2rem, 1.55rem + 1.8vw, 2.75rem)",
      "displayMd": "clamp(1.625rem, 1.4rem + 0.9vw, 2rem)",
      "title": "1.375rem",
      "bodyLg": "1.1875rem",
      "body": "1.0625rem",
      "bodySm": "0.9375rem",
      "label": "0.8125rem",
      "caption": "0.75rem"
    }
  },
  "spacing": {
    "basePx": 4,
    "scale": {
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.5rem",
      "6": "2rem",
      "7": "3rem",
      "8": "4rem",
      "9": "6rem"
    },
    "sectionY": "clamp(3.5rem, 2.5rem + 4vw, 6rem)",
    "gutter": "clamp(1.25rem, 1rem + 2vw, 2rem)",
    "contentMax": "68rem",
    "proseMax": "38rem"
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.75rem",
    "lg": "1.25rem",
    "pill": "999px"
  },
  "motion": {
    "easeOut": "cubic-bezier(0.22, 1, 0.36, 1)",
    "fast": "140ms",
    "med": "280ms",
    "slow": "520ms",
    "respectPrefersReducedMotion": true
  },
  "contrast": {
    "wcagTarget": "AA",
    "measured": {
      "nightTealOnMist": 10.86,
      "mistOnNightTeal": 10.86,
      "mistOnPorchBlue": 8.21,
      "nightTealOnWindowWarm": 8.91,
      "nightTealOnAmber": 5.46,
      "mutedOnMist": 6.58,
      "porchBlueLinkOnMist": 8.21,
      "stakesTextOnMist": 5.53
    },
    "approvedPairs": [
      { "fg": "#163A3F", "bg": "#EEF2EF", "use": "body text on page" },
      { "fg": "#EEF2EF", "bg": "#163A3F", "use": "text on inverse / dusk bands" },
      { "fg": "#EEF2EF", "bg": "#2C4A62", "use": "text on porch dusk" },
      { "fg": "#163A3F", "bg": "#F3D9A0", "use": "text on settle / soft highlight" },
      { "fg": "#163A3F", "bg": "#E4A01A", "use": "CTA label on amber glow button" },
      { "fg": "#3d5a5e", "bg": "#EEF2EF", "use": "muted labels / captions" },
      { "fg": "#2C4A62", "bg": "#EEF2EF", "use": "inline links" },
      { "fg": "#a63f28", "bg": "#EEF2EF", "use": "stakes / alert small text (--ll-color-stakes-text)" }
    ],
    "doNotUse": [
      { "fg": "#E4A01A", "bg": "#EEF2EF", "reason": "fails AA for small text (1.99:1)" },
      { "fg": "#8FA88A", "bg": "#EEF2EF", "reason": "muted only; not body text (2.28:1)" },
      { "fg": "#C6D96A", "bg": "#EEF2EF", "reason": "decorative neighbor accent only (1.37:1)" },
      { "fg": "#D45A3A", "bg": "#EEF2EF", "reason": "raw Ember Coral fails AA for small text (3.49:1); use --ll-color-stakes-text" }
    ]
  },
  "a11y": {
    "importOrder": ["tokens.css", "components.css", "a11y.css"],
    "required": [
      "skip link to #main-content",
      "single h1 per page",
      "header/nav/main/footer landmarks",
      "aria-current=page on active nav (underline + weight)",
      "meaningful alt on content images; empty alt + aria-hidden on decorative",
      "keyboard operable mobile nav with Escape to close",
      "prefers-reduced-motion respected (a11y.css)"
    ],
    "breakpoints": {
      "navCollapseMax": "719px",
      "heroSplitMin": "860px",
      "testWidths": [320, 375, 768, 1024, 1280]
    }
  }
}
